{
  "name": "simpleui-node-orchestrator",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "description": "WebUI and hook runner for managing Hysteria2 and Trojan nodes across multiple servers.",
  "author": "Hill-1024",
  "homepage": "https://github.com/Hill-1024/simpleUI",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hill-1024/simpleUI.git"
  },
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"pnpm:dev:api\" \"pnpm:dev:web\"",
    "dev:api": "node --watch server/index.js",
    "dev:web": "vite --host 0.0.0.0",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "desktop": "electron desktop/main.cjs",
    "desktop:dev": "SIMPLEUI_DESKTOP_DEV=1 electron desktop/main.cjs",
    "desktop:pack": "pnpm build && electron-builder --dir",
    "desktop:dist": "pnpm build && electron-builder",
    "desktop:dist:win": "pnpm build && electron-builder --win nsis zip --publish never",
    "desktop:dist:mac": "pnpm build && electron-builder --mac dmg zip --publish never",
    "desktop:dist:linux": "pnpm build && electron-builder --linux deb zip --publish never",
    "check": "node --check server/index.js && node --check server/lib/db.js && node --check server/lib/hook-agent.js && node --check server/lib/jobs.js && node --check server/lib/providers.js && node --check server/lib/ssh.js && node --check desktop/main.cjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "lucide-vue-next": "^0.468.0",
    "ssh2": "^1.17.0",
    "uuid": "^11.0.5",
    "vite": "^7.1.9",
    "vue": "^3.5.22",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "dev.simpleui.node-orchestrator",
    "productName": "SimpleUI",
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "server/**/*",
      "desktop/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "artifactName": "${productName}_${version}_Windows_${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}_${version}_macOS_${arch}.${ext}"
    },
    "linux": {
      "category": "Network",
      "maintainer": "Hill-1024 <3520363913@qq.com>",
      "target": [
        "deb",
        "zip"
      ],
      "artifactName": "${productName}_${version}_Linux_${arch}.${ext}"
    }
  }
}
